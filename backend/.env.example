# ── Server ──
PORT=4000
# Origin allowed to call this API from the browser (the frontend)
CORS_ORIGIN=http://localhost:3000

# ── Supabase ──
# Service-role key is used for DB access (brands/campaigns); URL + key also back JWT verification.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: only needed if you switch to local JWT verification instead of auth.getUser
SUPABASE_JWT_SECRET=

# ── Upstash Redis (rate limiting + provider cache) ──
# Leave blank to disable rate limiting and run the provider without caching.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── RapidAPI (real Instagram data) — OPT-IN ──
# Live data is OFF by default; the app uses the unlimited generated sample dataset
# and never calls the API. Set RAPIDAPI_ENABLED=true ONLY when you have a key with
# enough monthly quota (the free 30/mo tier is not enough).
RAPIDAPI_ENABLED=
# Configured for "Instagram Scraper 2025": host instagram-scraper-20251.p.rapidapi.com
RAPIDAPI_KEY=
RAPIDAPI_HOST=instagram-scraper-20251.p.rapidapi.com
# Profile endpoint path for that product (override if you switch products):
RAPIDAPI_PROFILE_PATH=/userinfo/
# Cache priced creators per niche this many seconds, to conserve the monthly request
# quota (default 7 days = 604800). Clear Redis creators:* keys to force a refetch.
CREATORS_CACHE_TTL_SEC=604800

# ── Pricing ──
# Active model: cpm | weighted | tier_flat
PRICING_MODEL=cpm
# Optional tuning overrides (defaults applied when unset). Examples:
# CPM_NANO=150  CPM_MICRO=300  CPM_MACRO=550
# ENG_MULTIPLIER_K=4  PRICE_SPREAD=0.2  W_NORM_K=50000
# TIER_AVG_ENG_NANO=0.06  TIER_AVG_ENG_MICRO=0.045  TIER_AVG_ENG_MACRO=0.03
