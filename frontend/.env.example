# Copy this file to .env.local and fill in real values.

# ── Upstash Redis — API rate limiting (https://console.upstash.com) ──────────
# When left blank, the rate-limit middleware passes through (fine for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Supabase — email + password auth (https://supabase.com/dashboard) ────────
# Found under Project Settings → API. When left blank, auth is disabled and the
# dashboard stays open (demo mode); the /login page shows a "not configured" note.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
